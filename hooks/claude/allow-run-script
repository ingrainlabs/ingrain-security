#!/usr/bin/env bash
# The RUN grant on Claude Code — PreToolUse (Codex twin: hooks/codex/allow-run-script).
#
# Auto-approves a Bash call when it is a bare run of one of the scripts in
# skills/ingrain-security/scripts/run/. The qualifying test lives beside them in
# run/allow-run-check.sh. Never emits "deny": anything that does not qualify defers to the
# normal prompt.
#
# Its sibling grant is hooks/claude/allow-write-assessment, which approves a WRITE to the
# assessment file — different tool, different guard.
#
# Registered in hooks/claude/hook.json, dispatched via hooks/run-hook.cmd. Always exits 0.

# Print nothing and exit 0: no opinion, use the normal permission flow. Installed as the EXIT
# trap and paired with `set -e`, so EVERY failure below — a malformed payload, a missing
# folder, a check that says no — lands here, and the final printf is the one path that escapes
# it. That also forces exit 0 on every path: a hook error must not break the user's tool call.
defer() {
    exit 0
}
trap defer EXIT
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd -P)"
SCRIPTS="${SCRIPT_DIR}/../../skills/ingrain-security/scripts"
# shellcheck source=../../skills/ingrain-security/scripts/lib/hook-input.sh
. "${SCRIPTS}/lib/hook-input.sh" 2>/dev/null
# shellcheck source=../../skills/ingrain-security/scripts/lib/path.sh
. "${SCRIPTS}/lib/path.sh" 2>/dev/null
# shellcheck source=../../skills/ingrain-security/scripts/run/allow-run-check.sh
. "${SCRIPTS}/run/allow-run-check.sh" 2>/dev/null

main() {
    # Declared apart from their assignments on purpose: `local x="$(cmd)"` reports the status
    # of `local`, which would hide a failed extraction from errexit.
    local payload tool command cwd run_dir

    payload="$(cat)"
    [ -n "${payload}" ]

    # The hook.json matcher is a convenience filter, not a security boundary.
    tool="$(extract_string "${payload}" ".tool_name")"
    [ "${tool}" = "Bash" ]

    command="$(extract_string "${payload}" ".tool_input.command")"
    [ -n "${command}" ]

    run_dir="$(runnable_scripts_dir "${PLUGIN_ROOT}")"
    [ -n "${run_dir}" ]

    # An absent cwd is tolerated, not a defer: the path helpers fall back to $PWD.
    cwd="$(extract_string "${payload}" ".cwd")" || cwd=""
    is_allowed_run_command "${run_dir}" "${cwd}" "${command}"

    printf '%s\n' \
        '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow","permissionDecisionReason":"ingrain-security runnable script"}}'
}

main "$@"
