#!/usr/bin/env bash
# PreToolUse hook for the ingrain-security plugin (Claude Code only — the Codex twin is
# hooks/codex/allow-script-run, on the PermissionRequest event).
#
# Auto-approves a Bash call ONLY when it is a bare run of one of this plugin's own
# read-only scripts, so a review can mint its paths, read the branch delta and re-validate
# the assessment without a permission prompt on every step. The skill asks for
# `validate-assessment` after EVERY worker writes, so this is the difference between a
# review that runs and one that stops to ask a dozen times.
#
# This is the command-side twin of allow-assessment-write, and the same reasoning picked
# the mechanism: a plugin cannot ship `permissions.allow` rules (plugin settings.json
# supports only `agent` and `subagentStatusLine`), and a PreToolUse `permissionDecision:
# "allow"` is the one plugin-shippable way to bypass the prompt.
#
# Approving a COMMAND is a wider grant than approving a file write, so the test is
# correspondingly strict — see skills/ingrain-security/scripts/lib/script-run.sh, which
# holds it and the parsing shared with the Codex hook. In short, a command qualifies only
# when every character is on an allowlist that excludes chaining, redirection, substitution
# and expansion; it tokenizes to `[bash] <script> [args…]` with no interpreter flag; and
# that script resolves, physically, to an allowlisted name directly inside THIS plugin's
# scripts/ directory. Arguments are deliberately not inspected: all four scripts are
# read-only, so the worst a hostile argument buys is a file read the agent could already
# perform with the Read tool.
#
# This hook NEVER emits "deny": it can only remove a prompt, never introduce a block. Any
# doubt — a malformed payload, an unparseable command, a script outside the plugin — falls
# through to "defer" (empty stdout), which leaves the user's normal permission prompt in
# place. Failing closed here means failing to an ordinary prompt, never to a blocked
# session.
#
# Registered in hooks/claude/hook.json, dispatched via hooks/run-hook.cmd. Exits 0 always:
# a hook error must not break the user's tool call.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd -P)" || exit 0
# shellcheck source=../../skills/ingrain-security/scripts/lib/project-root.sh
. "${SCRIPT_DIR}/../../skills/ingrain-security/scripts/lib/project-root.sh" 2>/dev/null || exit 0
# shellcheck source=../../skills/ingrain-security/scripts/lib/assessment-write.sh
. "${SCRIPT_DIR}/../../skills/ingrain-security/scripts/lib/assessment-write.sh" 2>/dev/null || exit 0
# shellcheck source=../../skills/ingrain-security/scripts/lib/script-run.sh
. "${SCRIPT_DIR}/../../skills/ingrain-security/scripts/lib/script-run.sh" 2>/dev/null || exit 0

# Print nothing and exit 0 — the universal "no opinion, use the normal permission flow"
# signal. Every rejection path in this hook routes here.
defer() {
    exit 0
}

main() {
    local payload tool command cwd scripts_dir

    payload="$(cat)" || defer
    [ -n "${payload}" ] || defer

    # The hook.json matcher is a convenience filter, not a security boundary — re-check.
    tool="$(extract_string "${payload}" ".tool_name")" || defer
    [ "${tool}" = "Bash" ] || defer

    command="$(extract_string "${payload}" ".tool_input.command")" || defer
    [ -n "${command}" ] || defer

    scripts_dir="$(script_run_dir "${PLUGIN_ROOT}")" || defer
    [ -n "${scripts_dir}" ] || defer

    cwd="$(extract_string "${payload}" ".cwd")" || cwd=""
    is_allowed_script_command "${scripts_dir}" "${cwd}" "${command}" || defer

    printf '%s\n' \
        '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow","permissionDecisionReason":"ingrain-security bundled script"}}'
}

main "$@"
exit 0
