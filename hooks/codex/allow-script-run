#!/usr/bin/env bash
# PermissionRequest hook (Codex; Claude Code twin: hooks/claude/allow-script-run).
#
# Auto-approves a shell call when it is a bare run of one of this plugin's read-only
# scripts. Codex passes `tool_input.command` as either a string or an argv array (commonly
# the `bash -lc "<command>"` wrapper); both shapes are handled, and the wrapper's string
# argument is re-parsed rather than trusted. The qualifying test lives in
# skills/ingrain-security/scripts/lib/script-run.sh, shared with the Claude hook.
# Never denies: anything that does not qualify defers to the normal approval prompt.
#
# Registered in hooks/codex/hook.json, dispatched via hooks/run-hook.cmd. Always exits 0.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd -P)" || exit 0
# shellcheck source=../../skills/ingrain-security/scripts/lib/project-root.sh
. "${SCRIPT_DIR}/../../skills/ingrain-security/scripts/lib/project-root.sh" 2>/dev/null || exit 0
# shellcheck source=../../skills/ingrain-security/scripts/lib/assessment-write.sh
. "${SCRIPT_DIR}/../../skills/ingrain-security/scripts/lib/assessment-write.sh" 2>/dev/null || exit 0
# shellcheck source=../../skills/ingrain-security/scripts/lib/script-run.sh
. "${SCRIPT_DIR}/../../skills/ingrain-security/scripts/lib/script-run.sh" 2>/dev/null || exit 0

# Print nothing and exit 0: no opinion, use the normal approval flow.
defer() {
    exit 0
}

main() {
    local payload tool command cwd scripts_dir

    payload="$(cat)" || defer
    [ -n "${payload}" ] || defer

    # The hook.json matcher is a convenience filter, not a security boundary.
    tool="$(extract_string "${payload}" ".tool_name")" || defer
    case "${tool}" in
        shell | local_shell) ;;
        *) defer ;;
    esac

    scripts_dir="$(script_run_dir "${PLUGIN_ROOT}")" || defer
    [ -n "${scripts_dir}" ] || defer

    cwd="$(extract_string "${payload}" ".cwd")" || cwd=""

    # Argv array first; when the command is a string, extraction fails and the string
    # parser answers instead.
    if extract_string_array "${payload}" ".tool_input.command"; then
        is_allowed_script_exec "${scripts_dir}" "${cwd}" "${SCRIPT_RUN_ARGV[@]}" || defer
    else
        command="$(extract_string "${payload}" ".tool_input.command")" || defer
        is_allowed_script_command "${scripts_dir}" "${cwd}" "${command}" || defer
    fi

    printf '%s\n' \
        '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"allow"}}}'
}

main "$@"
exit 0
