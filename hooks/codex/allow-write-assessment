#!/usr/bin/env bash
# The WRITE grant on Codex — PermissionRequest (the Claude Code twin is
# hooks/claude/allow-write-assessment, on the PreToolUse event).
#
# Auto-approves an apply_patch ONLY when every file it touches is the assessment file this
# plugin mints, so a review can write its analysis without an approval prompt on every
# edit. Everything else defers to Codex's normal approval flow.
#
# Why PermissionRequest and not PreToolUse: on Codex, PreToolUse's `permissionDecision`
# exists to REWRITE a call (`updatedInput`) or deny it, and its legacy `decision:
# "approve"` is documented as parsed-but-not-supported. PermissionRequest is the event that
# skips the prompt — it runs only when Codex is about to ask for approval, and an `allow`
# lets the request proceed without surfacing the prompt. If no hook decides, the normal
# approval flow stands.
#
# Codex edits files through a single `apply_patch` tool whose patch text arrives in
# `tool_input.command` — there is no `file_path` field, and ONE patch can touch SEVERAL
# files. So the targets are read out of the patch envelope, and the approval is all-or-
# nothing: a patch that edits the assessment and a source file in one shot is deferred
# whole, because Codex applies it atomically and a partial grant is not available to us.
#
# The grant is deliberately narrow. A patch is approved only when ALL hold:
#   - the tool is apply_patch (or its Edit / Write matcher aliases) — never Bash, where
#     approving a command string would be a completely different grant,
#   - the command is a PURE patch: nothing outside the `*** Begin Patch` / `*** End Patch`
#     envelope but an apply_patch/heredoc wrapper, so no `; curl evil` can ride along,
#   - it only ADDS or UPDATES files — a Delete/Move is outside what the skill ever does,
#   - every path it touches passes `is_allowed_write_target` (direct child of the project's
#     `.ingrain-security/` folder, named `assessment*.md`, no symlink in the way).
#
# Its sibling grant is hooks/codex/allow-run-script, which approves a RUN of one of the
# scripts in scripts/run/ — different tool, different guard.
#
# This hook NEVER denies: it can only remove a prompt, never introduce a block. Any doubt —
# a malformed payload, an unrecognized envelope line, a missing folder — falls through to
# "defer" (empty stdout), which leaves Codex's normal approval prompt in place. Failing
# closed here means failing to an ordinary prompt, never to a blocked session.
#
# Registered in hooks/codex/hook.json, dispatched via hooks/run-hook.cmd. Exits 0 always: a
# hook error must not break the user's tool call.

# Print nothing and exit 0 — the universal "no opinion, use the normal approval flow"
# signal. Installed as the EXIT trap and paired with `set -e`, so every rejection path in this
# hook routes here without having to say so line by line, and the final printf is the one path
# that escapes it. That also forces exit 0 on every path: a hook error must not break the
# user's tool call.
defer() {
    exit 0
}
trap defer EXIT
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPTS="${SCRIPT_DIR}/../../skills/ingrain-security/scripts"
# shellcheck source=../../skills/ingrain-security/scripts/lib/project-root.sh
. "${SCRIPTS}/lib/project-root.sh" 2>/dev/null
# shellcheck source=../../skills/ingrain-security/scripts/lib/hook-input.sh
. "${SCRIPTS}/lib/hook-input.sh" 2>/dev/null
# shellcheck source=../../skills/ingrain-security/scripts/lib/path.sh
. "${SCRIPTS}/lib/path.sh" 2>/dev/null
# shellcheck source=../../skills/ingrain-security/scripts/write/lib/allow-write-check.sh
. "${SCRIPTS}/write/lib/allow-write-check.sh" 2>/dev/null

# Collect the paths an apply_patch command touches, one per line, or return non-zero when
# the command is anything other than a pure add/update patch.
#
# The patch body is attacker-influenceable text, so the parse keys on structure the body
# cannot forge: envelope lines sit at column 0, while every line of a hunk is prefixed
# (` `, `+`, `-`). A decoy `*** Add File: /etc/passwd` written INTO an assessment is
# therefore a `+`-prefixed content line, and is ignored — as it should be, since what the
# assessment says is none of this hook's business.
#
# Anything unrecognized is a refusal, not a skip: an envelope verb this hook does not know
# is exactly the case where it must not be guessing.
collect_patch_paths() {
    local patch="$1"

    # Carried across iterations and read after the loop, so these keep their defaults up front.
    local region="prefix" count=0 saw_opener=0 terminator="" closed=0

    # `apply_patch`, optionally opening a heredoc: `apply_patch <<'EOF'`, `<<-"PATCH"`, …
    # Group 2 captures the delimiter, so the suffix can be held to the one actually opened.
    local opener_re="^apply_patch([[:space:]]+<<-?[\"']?([A-Za-z_][A-Za-z0-9_]*)[\"']?)?[[:space:]]*\$"

    local line
    while IFS= read -r line; do
        line="${line%$'\r'}"

        case "${region}" in
            # Before the patch: ONE wrapper line, and only the wrapper Codex may put there —
            # bare `apply_patch`, or `apply_patch <<'EOF'`. Nothing else, which is what stops
            # a chained shell command from being approved along with the patch.
            prefix)
                if [ -z "${line}" ]; then
                    continue
                fi
                if [ "${line}" = "*** Begin Patch" ]; then
                    region="body"
                    continue
                fi
                [ "${saw_opener}" -eq 0 ] || return 1
                [[ "${line}" =~ ${opener_re} ]] || return 1
                saw_opener=1
                terminator="${BASH_REMATCH[2]}"
                ;;

            body)
                if [ "${line}" = "*** End Patch" ]; then
                    region="suffix"
                    continue
                fi
                # A hunk's own lines are prefixed, so an unprefixed `*** …` is an envelope
                # line and must be one this hook understands.
                case "${line}" in
                    '*** Add File: '* | '*** Update File: '*)
                        printf '%s\n' "${line#*File: }"
                        count=$((count + 1))
                        ;;
                    '*** End of File') ;;
                    '***'*) return 1 ;;
                esac
                ;;

            # After the patch: EXACTLY the delimiter the wrapper opened, once, and nothing
            # after it. A wrapper that opened no heredoc leaves nothing legal here at all —
            # otherwise a bareword line like `reboot`, which needs no argument and so carries
            # none of the spaces the envelope check would catch, is a second shell command
            # riding along on the patch's approval.
            suffix)
                if [ -z "${line}" ]; then
                    continue
                fi
                [ -n "${terminator}" ] || return 1
                [ "${closed}" -eq 0 ] || return 1
                [ "${line}" = "${terminator}" ] || return 1
                closed=1
                ;;
        esac
    done < <(printf '%s\n' "${patch}")

    # A truncated patch, or one that touches nothing, is not something to approve.
    [ "${region}" = "suffix" ] || return 1
    [ "${count}" -gt 0 ] || return 1
    # Likewise a heredoc that was opened and never closed: a truncated command, not a patch.
    [ -z "${terminator}" ] || [ "${closed}" -eq 1 ] || return 1
}

main() {
    # Every `local` below sits on its own line, apart from its assignment: `local x="$(cmd)"`
    # reports the status of `local`, which would hide a failed extraction from errexit.
    local payload
    payload="$(cat)"
    [ -n "${payload}" ]

    # The hook.json matcher is a convenience filter, not a security boundary — re-check.
    # Codex reports `apply_patch`; Edit / Write are its documented matcher aliases and are
    # accepted in case a future version reports one of them instead.
    local tool
    tool="$(extract_string "${payload}" ".tool_name")"
    case "${tool}" in
        apply_patch | Edit | Write) ;;
        *) defer ;;
    esac

    local patch
    patch="$(extract_string "${payload}" ".tool_input.command")"
    [ -n "${patch}" ]

    local paths
    paths="$(collect_patch_paths "${patch}")"
    [ -n "${paths}" ]

    local canon_dir
    canon_dir="$(canonical_assessment_dir "codex")"
    [ -n "${canon_dir}" ]

    # All-or-nothing: one path outside the grant defers the whole patch.
    # An absent cwd is tolerated, not a defer: absolutize falls back to $PWD.
    local cwd
    cwd="$(extract_string "${payload}" ".cwd")" || cwd=""

    local path
    while IFS= read -r path; do
        [ -n "${path}" ]
        is_allowed_write_target "${canon_dir}" "$(absolutize "${path}" "${cwd}")"
    done < <(printf '%s\n' "${paths}")

    printf '%s\n' \
        '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"allow"}}}'
}

main "$@"
