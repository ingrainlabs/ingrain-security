{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" start/session-start codex",
            "statusMessage": "Loading ingrain-security context"
          },
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" start/ensure-assessment-dir codex",
            "statusMessage": "Preparing security-assessment folder"
          }
        ]
      }
    ]
  }
}
