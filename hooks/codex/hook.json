{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" start/session-start codex",
            "statusMessage": "Loading ingrain-security context"
          },
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" start/ensure-assessment-dir codex",
            "statusMessage": "Preparing security-assessment folder"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" codex/allow-write-assessment",
            "statusMessage": "Checking assessment-file write"
          }
        ]
      },
      {
        "matcher": "shell|local_shell",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" codex/allow-run-script",
            "statusMessage": "Checking runnable-script run"
          }
        ]
      }
    ]
  }
}
