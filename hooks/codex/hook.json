{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "statusMessage": "Loading ingrain-security context"
          },
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}/hooks/run-hook.cmd\" scripts/ensure-assessment-dir",
            "statusMessage": "Preparing security-assessment folder"
          }
        ]
      }
    ]
  }
}
