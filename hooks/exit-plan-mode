#!/usr/bin/env bash
# PostToolUse hook for ExitPlanMode in the ingrain-security plugin.
#
# Fires after a plan is approved (ExitPlanMode succeeds) and injects an
# instruction telling the agent to run the ingrain-security skill before
# writing any code.

set -euo pipefail

context="<EXTREMELY_IMPORTANT>\nThe implementation plan was just approved (ExitPlanMode). Before writing ANY code, you MUST now run the 'ingrain-security' skill via the Skill tool. Do not begin implementation until the security review finishes.\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON in the Claude Code shape
# (hookSpecificOutput.additionalContext).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "PostToolUse",\n    "additionalContext": "%s"\n  }\n}\n' "$context"

exit 0
