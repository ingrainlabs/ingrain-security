#!/usr/bin/env bash
# Finalize helper for the ingrain-security plugin.
#
# Copies the current review's working analysis — the most-recently-modified
# .claude/.temp/assessment*.md (the working file is uniquely named per run) —
# into the durable ingrain-securityAssessment/ folder as a timestamped snapshot.
# The ingrain-security skill invokes this at its finalize step as a FIXED,
# ARGUMENT-LESS command:
#
#     "${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd" save-assessment
#
# Security: the working file is found by globbing (NO path argument), and the
# task title is READ FROM THAT FILE, never passed on the command line — keeping
# untrusted / LLM-minted data off argv and off the Windows run-hook.cmd %2..%9
# batch layer (where cmd.exe interprets metacharacters before bash runs). DO NOT
# add a positional argument to this script. Symlinked source files are skipped so
# a planted link can't be read or copied out of the repo (T6).

set -euo pipefail

project_root="${CLAUDE_PROJECT_DIR:-$PWD}"
assessment_dir="${project_root}/ingrain-securityAssessment"
temp_dir="${project_root}/.claude/.temp"

# Locate THIS review's working analysis WITHOUT a path argument: the
# most-recently-modified assessment*.md in the temp dir (the working file is
# uniquely named per run — plan basename in plan mode, timestamp+random ad-hoc).
# Argument-less on purpose — no path crosses the command line. Skip symlinks so a
# planted symlinked source is never read or copied out of the repo (T6).
source_file=""
shopt -s nullglob
for candidate in "${temp_dir}"/assessment*.md; do
    [ -L "${candidate}" ] && continue
    [ -f "${candidate}" ] || continue
    if [ -z "${source_file}" ] || [ "${candidate}" -nt "${source_file}" ]; then
        source_file="${candidate}"
    fi
done
shopt -u nullglob

# Nothing to sync if there is no (non-symlink) working analysis.
if [ -z "${source_file}" ]; then
    echo "save-assessment: no assessment*.md in ${temp_dir}; nothing to sync" >&2
    exit 0
fi

# Derive the filename from the task Title in the assessment file (M2). Read only
# the first `Title:` line; the on-disk schema (references/assessment-file.md)
# writes it as a single line under `## Task`. Strip the label with parameter
# expansion — no sed/awk, no untrusted data on any command line.
title_line="$(grep -m1 -E '^Title:' "${source_file}" 2>/dev/null || true)"
raw_title="${title_line#Title:}"

# Normalize to a slug, THEN fail-closed on an anchored allowlist (M3). The tr
# pipeline can only emit [a-z0-9-]; the case check is the authoritative backstop
# so a slug can never carry `/`, `..`, NUL, or a leading `-`.
slug="$(printf '%s' "${raw_title}" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | tr -s '-')"
slug="${slug#-}"
slug="${slug%-}"
slug="${slug:0:80}"
slug="${slug%-}"
case "${slug}" in
    "" | *[!a-z0-9-]*) slug="" ;;  # unusable -> timestamp-only fallback
esac

timestamp="$(date +%Y%m%d-%H%M%S)"
if [ -n "${slug}" ]; then
    dest_name="assessment-${slug}-${timestamp}.md"
else
    dest_name="assessment-${timestamp}.md"
fi

# Never follow a pre-placed symlink at the target — this is where the sensitive
# assessment lands, so a planted link must not redirect it outside the repo (M4).
if [ -L "${assessment_dir}" ]; then
    echo "save-assessment: refusing symlinked target ${assessment_dir}" >&2
    exit 1
fi

mkdir -p "${assessment_dir}"
cp -- "${source_file}" "${assessment_dir}/${dest_name}"

echo "save-assessment: wrote ingrain-securityAssessment/${dest_name}" >&2
exit 0
