#!/usr/bin/env bash
# SessionStart hook for the ingrain-security plugin.
#
# Ensures the security-assessment folder exists in the USER's project (the repo
# where Claude Code / Codex is running) so finalized analyses have a durable home
# outside the gitignored .claude/ working tree. Creates it only when absent.
#
# Emits NOTHING on stdout: SessionStart stdout is injected into the session
# context, and this hook has no context to add.
#
# Unlike sibling hooks this uses `set -uo pipefail` WITHOUT `-e`: a failed write
# (a permission error, or a refused symlink target) must never abort the user's
# session. Every write is guarded and the script always reaches `exit 0`.
#
# Shared by both platforms; registered in hooks/claude/hook.json and
# hooks/codex/hook.json and dispatched through hooks/run-hook.cmd.

set -uo pipefail

# Normalize a directory to an absolute, canonical forward-slash path. An empty argument
# or an unreachable directory yields empty output and a non-zero status, so callers fall
# through to the next candidate.
#
# The `cd && pwd` idiom (same as session-start) normalizes the value so mkdir,
# symlink tests and the printf writes work under Git Bash on Windows, where
# CLAUDE_PROJECT_DIR is a native backslash path that MSYS does not convert for env
# vars.
normalize_dir() {
    [ -n "${1:-}" ] || return 1
    cd "$1" 2>/dev/null && pwd
}

# The root of the git repository containing the current directory; empty when outside a
# repo. `rev-parse --show-toplevel` answers from ANY subdirectory, so the folder is
# seeded at the top of the repo even when the host starts us in one of its children.
resolve_git_root() {
    git rev-parse --show-toplevel 2>/dev/null
}

# Resolve the user's PROJECT root — NOT the plugin root. Shared verbatim with
# scripts/assessment-path. The host is passed as $1 by each hook.json:
#   - codex: Codex exports no project-dir variable, so we resolve from the git repo
#     root, falling back to $PWD. We deliberately IGNORE CLAUDE_PROJECT_DIR even if it
#     leaked into the environment (e.g. a shell that also ran Claude Code) — honoring a
#     stray Claude var would seed the folder in the wrong project.
#   - claude (default): CLAUDE_PROJECT_DIR is authoritative and outranks git, so a cwd
#     inside a vendored nested repo cannot retarget the folder; git root, then $PWD,
#     back it up.
#
# Echoes empty on failure — callers no-op rather than risk writing to the filesystem
# root (there is no `set -e` to abort us).
resolve_project_root() {
    local root
    if [ "${1:-}" != "codex" ]; then
        root="$(normalize_dir "${CLAUDE_PROJECT_DIR:-}")" && [ -n "${root}" ] && {
            printf '%s' "${root}"
            return 0
        }
    fi
    root="$(normalize_dir "$(resolve_git_root)")" && [ -n "${root}" ] && {
        printf '%s' "${root}"
        return 0
    }
    normalize_dir "$PWD"
}

# Seed README.md on first creation only — never clobber a user-edited one.
# printf (not a heredoc) — documented bash 5.3 heredoc hang.
seed_readme() {
    local readme="$1/README.md"
    [ -f "${readme}" ] && return 0
    printf '%s\n' \
        '# Threat assessments' \
        '' \
        'Point-in-time threat assessments produced by the `ingrain-security`' \
        'plugin at the end of each security-review run.' \
        '' \
        'Each file is keyed by branch and task, named' \
        '`assessment-<branch>-<task-slug>.md` (an unresolvable segment is dropped). It is' \
        'both the live working copy a review writes and its persisted record — the same' \
        'file is updated in place, and re-reviewing the same task on the same branch' \
        'resumes it. Different tasks and branches get their own files.' \
        '' \
        'This folder is git-ignored by default (see the `.gitignore` here): an' \
        'assessment can contain analysis of your private codebase, so it is not' \
        'committed unless you explicitly `git add -f <file>` one to share it.' \
        > "${readme}" 2>/dev/null || true
}

# Idempotently ensure the self-ignoring .gitignore (M5) so a routine `git add -A`
# cannot sweep up the sensitive assessments. The bare `*` matches this file too, so
# the whole folder — ignore file included — stays out of `git status`; `git add -f`
# remains the explicit escape hatch for sharing one file.
seed_gitignore() {
    local ignore="$1/.gitignore"
    [ -f "${ignore}" ] && return 0
    printf '%s\n' \
        '# Assessments here can contain analysis of a private codebase, so they' \
        '# are ignored by default. Share one explicitly with: git add -f <file>' \
        '*' \
        > "${ignore}" 2>/dev/null || true
}

main() {
    local host="${1:-}" project_root assessment_dir
    project_root="$(resolve_project_root "${host}")"
    [ -n "${project_root}" ] || return 0
    assessment_dir="${project_root}/ingrain-security"

    # Never follow a pre-placed symlink at the target — a crafted repo could point
    # it outside the tree. Silent no-op; this hook must not abort the session (M4).
    [ -L "${assessment_dir}" ] && return 0

    # Create the folder on first run.
    if [ ! -d "${assessment_dir}" ]; then
        mkdir -p "${assessment_dir}" 2>/dev/null || return 0
    fi

    seed_readme "${assessment_dir}"
    seed_gitignore "${assessment_dir}"
}

# No stdout on purpose (see header).
main "$@"
exit 0
