#!/usr/bin/env bash
# SessionStart hook for the ingrain-security plugin.
#
# Injects the ingrain-security skill into the session context so the
# agent knows to run the security review loop as a step of implementation
# planning -- while forming the plan, folding the results into it -- and to run
# the skill again (its Testing verification) once the code is written.

set -euo pipefail

# The host is passed as $1 by each hook.json ("claude" | "codex" | <future token>),
# matching ensure-assessment-dir. It selects the mint-assessment-path invocation below.
HOST="${1:-claude}"

# Determine plugin root directory. This script lives at hooks/start/session-start,
# so the plugin root is two levels up.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# Read the ingrain-security skill content
skill_path="${PLUGIN_ROOT}/skills/ingrain-security/SKILL.md"
review_skill_content=$(cat "$skill_path" 2>&1 || echo "Error reading ingrain-security skill at ${skill_path}")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

review_skill_escaped=$(escape_for_json "$review_skill_content")

# Concrete, ready-to-run mint-assessment-path command (plugin root + host already
# substituted) so the orchestrator never hand-builds the assessment-file path — it runs
# the plugin script and uses its JSON output. The orchestrator's own shell is
# bash, so it invokes the script directly (no run-hook.cmd wrapper needed — that only
# serves host-invoked hook commands). See SKILL.md → The assessment file.
runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/mint-assessment-path\" ${HOST}")
# Twin runner for the org-rules sidecar, minted the same way and keyed by the same
# branch + task slug (see SKILL.md → rules-file.md). Only written at planning time when
# org rules are retrieved; the verification skill reads it back by re-minting this path.
rules_runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/mint-rules-path\" ${HOST}")
# Third runner: the branch-delta resolver. It mints nothing — it resolves the DIFF BASIS
# (the fork point this branch was cut from), which Phase select routes on and Testing
# diffs against. Read-only. See SKILL.md → Phase select and verification-pass.md → The
# diff under review.
branch_delta_runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/resolve-branch-delta\" ${HOST}")
# Fourth runner: the schema validator, run after every write to either file above. Takes a
# FILE PATH, not a host, so no ${HOST} is appended.
validate_runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/validate-assessment\"")
paths_context="<INGRAIN-ASSESSMENT-PATHS>\nRun these plugin scripts (paths + host already filled in); use their JSON output — never hand-build an assessment path or a merge-base.\n\n1) Assessment file — mint once at review start:\n\n  ${runner_escaped} mint --title \\\"<task title>\\\"\n\n-> Write ONLY to **assessment_abs** (the ABSOLUTE path) — every worker dispatch, every Write/Edit, and finalize; obey the JSON's \\\"instruction\\\" field. assessment_path is the display form (prose/links), never a write target; never create a second .ingrain-security/ folder. The mint also SEEDS an empty skeleton when the file is absent — fill its sections in place. file_exists reports written CONTENT: true means you are resuming this task's prior analysis on this branch.\n\n2) Org-rules sidecar — mint the same way when rules are retrieved at the mitigation step:\n\n  ${rules_runner_escaped} mint --title \\\"<task title>\\\"\n\n-> Write the retrieved rules (id + title + full body) and the per-mitigation mapping to **rules_abs**. It shares the branch + task slug, PERSISTS past finalize, and the Testing pass re-mints this path to read the rules back. (An agent maintaining the assessment later re-mints via the command above rather than trusting a stored path.)\n\n3) Branch delta — resolve what to diff; never hand-roll a merge-base loop:\n\n  ${branch_delta_runner_escaped}\n\n-> Read **delta_empty** at Phase select: false means there is code for this task to verify (a clean working tree is NOT proof otherwise). For Testing keep **base_ref** (the parent, for the report) and **diff_ref** (what you actually diff against — pass it verbatim to every verifier, never HEAD); fallback=true means diff_ref is HEAD, per the JSON's \\\"reason\\\".\n\n4) Validate after EVERY write to assessment_abs — yours and every worker's on return (the workers hold no shell, so YOU run it):\n\n  ${validate_runner_escaped} <the absolute path just written> --lenient\n\n-> Keep --lenient while the run is in progress (mid-run the file is incomplete by design); DROP it at finalize. Exit 0 = valid; exit 1 lists each violation as <path>:<line>: <message> — fix exactly those and re-run, at most twice, then state in one line what remains rather than hand on a malformed file.\n</INGRAIN-ASSESSMENT-PATHS>"

session_context="<EXTREMELY_IMPORTANT>\nThis project treats security analysis as the final step of implementation planning. **Once your implementation plan is comprehensive and detailed — but before you present it or write any code — you MUST run the 'ingrain-security' skill on the finished plan and fold its results back into it.** Then run the same skill **again after the code is written** — its Testing verification — to check that the adopted mitigations were actually implemented, before you present or commit the change. The skill auto-detects which phase to run from repo state. Invoke it via the Skill tool. Its full content is reproduced below so you know what it does:\n\n${review_skill_escaped}\n\n${paths_context}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON in the Claude Code shape
# (hookSpecificOutput.additionalContext).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"

exit 0
