#!/usr/bin/env bash
# SessionStart hook for the ingrain-security plugin.
#
# Injects the ingrain-security skill into the session context so the
# agent knows to run the security review loop as a step of implementation
# planning -- while forming the plan, folding the results into it -- and to run
# the skill again (its Testing verification) once the code is written.

set -euo pipefail

# The host is passed as $1 by each hook.json ("claude" | "codex" | <future token>),
# matching ensure-assessment-dir. It selects the assessment-path invocation below.
HOST="${1:-claude}"

# Determine plugin root directory. This script lives at hooks/start/session-start,
# so the plugin root is two levels up.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# Read the ingrain-security skill content
skill_path="${PLUGIN_ROOT}/skills/ingrain-security/SKILL.md"
review_skill_content=$(cat "$skill_path" 2>&1 || echo "Error reading ingrain-security skill at ${skill_path}")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

review_skill_escaped=$(escape_for_json "$review_skill_content")

# Concrete, ready-to-run assessment-path command (plugin root + host already
# substituted) so the orchestrator never hand-builds the assessment-file path — it runs
# the bundled skill script and uses its JSON output. The orchestrator's own shell is
# bash, so it invokes the script directly (no run-hook.cmd wrapper needed — that only
# serves host-invoked hook commands). See SKILL.md → The assessment file.
runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/assessment-path\" ${HOST}")
# Twin runner for the org-rules sidecar, minted the same way and keyed by the same
# branch + task slug (see SKILL.md → rules-file.md). Only written at planning time when
# org rules are retrieved; the verification skill reads it back by re-minting this path.
rules_runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/rules-path\" ${HOST}")
# Third runner: the branch-delta resolver. It mints nothing — it resolves the DIFF BASIS
# (the fork point this branch was cut from), which Phase select routes on and Testing
# diffs against. Read-only. See SKILL.md → Phase select and verification-pass.md → The
# diff under review.
branch_diff_runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/branch-diff\" ${HOST}")
# Fourth runner: the schema validator for the two files the minters above name. It takes a
# FILE PATH, not a host — the schema comes from the basename — which is why no ${HOST} is
# appended here. Run after every write to either file. See SKILL.md → Finalize and
# references/formatting/assessment-file.md → Validation.
validate_runner_escaped=$(escape_for_json "bash \"${PLUGIN_ROOT}/skills/ingrain-security/scripts/validate-assessment\"")
paths_context="<INGRAIN-ASSESSMENT-PATHS>\nDo NOT hand-build the assessment-file path. Run this script once at review start and use its JSON output:\n\n  ${runner_escaped} mint --title \\\"<task title>\\\"\n\n-> Use **assessment_abs** (the ABSOLUTE path) as the ONE file for every worker dispatch, every Write/Edit, and at finalize. Obey the JSON's \\\"instruction\\\" field. Never create an .ingrain-security/ folder anywhere else — the script already created the only one, at the repo root. assessment_path is the relative display form; use it in prose and links, never as a write target.\n\nThe file is both the working copy and its persisted record — there is no separate temp file and no copy step. The mint also SEEDS the file with its empty skeleton (all headings, both table headers, the field labels) when it is not there yet — fill those sections in place rather than re-creating the page. file_exists reports written CONTENT, not the file's presence: an untouched skeleton reads as false, and file_exists=true means you are resuming the same task's prior analysis on this branch.\n\nWhen org security rules are retrieved during the mitigation step, mint the twin org-rules sidecar the same way and write the retrieved rules (id + title + full body) plus the per-mitigation mapping to **rules_abs**:\n\n  ${rules_runner_escaped} mint --title \\\"<task title>\\\"\n\nIt shares the assessment's branch + task slug — a sibling in the same folder — and PERSISTS (it is not deleted at finalize). The verification skill re-mints this same path to read the rule descriptions back.\n\nThe implementing agent maintaining an assessment later must re-run the command above and write to the assessment_abs it returns, rather than trusting a path stored in a plan file.\n\nDo NOT hand-roll a merge-base loop to work out what to diff. Run this read-only script to resolve the BRANCH DELTA — everything this branch added since it diverged from the branch it was cut from, committed AND uncommitted:\n\n  ${branch_diff_runner_escaped}\n\n-> At Phase select, read **delta_empty**: false means there is code for this task to verify (commits since the fork point, or an uncommitted change, or both). A clean working tree is NOT evidence that no code exists — by the time verification is due the implementation is usually committed.\n-> For Testing, keep **base_ref** (the parent branch, for the report) and **diff_ref** (the merge-base commit — what you actually diff against). diff_ref is the run's fixed basis: pass it verbatim to every verifier, never re-derive it per dispatch and never substitute HEAD. When fallback=true, diff_ref is HEAD and the JSON's \\\"reason\\\" says why; obey the \\\"instruction\\\" field, which states whether that narrows the review.\n\nEVERY time you finish writing assessment_abs — and every time a worker you dispatched returns from writing it — check that file against its schema. It is one call, and it is not optional:\n\n  ${validate_runner_escaped} <the absolute path just written> --lenient\n\nPass --lenient while the run is in progress (mid-run the file is incomplete by design); DROP it at finalize, where the file must be complete. Exit 0 = valid. Exit 1 prints each violation as <path>:<line>: <message> — fix exactly those and re-run, at most twice, then state in one line what is left rather than handing on a file you know is malformed. The workers hold no shell, so YOU run this for what they wrote.\n</INGRAIN-ASSESSMENT-PATHS>"

session_context="<EXTREMELY_IMPORTANT>\nThis project treats security analysis as the final step of implementation planning. **Once your implementation plan is comprehensive and detailed — but before you present it or write any code — you MUST run the 'ingrain-security' skill on the finished plan and fold its results back into it.** Then run the same skill **again after the code is written** — its Testing verification — to check that the adopted mitigations were actually implemented, before you present or commit the change. The skill auto-detects which phase to run from repo state. Invoke it via the Skill tool. Its full content is reproduced below so you know what it does:\n\n${review_skill_escaped}\n\n${paths_context}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON in the Claude Code shape
# (hookSpecificOutput.additionalContext).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"

exit 0
