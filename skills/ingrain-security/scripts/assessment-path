#!/usr/bin/env bash
# Assessment-path minter for the ingrain-security plugin.
#
# Single source of truth for the review's assessment-file path, so the orchestrator
# never hand-builds it. The file is written directly into `ingrain-security/` at the
# project root and is BOTH the living working copy (workers write it during the run)
# and its persisted record — there is no separate temp file and no finalize copy.
# Emits ONE JSON object on stdout; diagnostics go to stderr.
#
# Usage:
#   assessment-path <host> mint --title "<task title>" [--branch-slug <slug>]
#   assessment-path --help
#
#   <host>  the host's config dotfolder base name — "claude" (Claude Code), "codex"
#           (Codex), or any future coding agent's token. It no longer appears in the
#           assessment path (that always lives at `ingrain-security/…`); it only
#           selects project-root resolution, exactly like `ensure-assessment-dir`.
#
# The path is deterministic in the branch + task, so it doubles as the task identity:
#   ingrain-security/assessment-<branch-slug>-<task-slug>.md
# Re-reviewing the SAME task on the SAME branch resolves to the SAME file (the run
# resumes/updates it in place — `file_exists` reports this); a different task or branch
# resolves to a different file. No timestamp, no random token.
#
# Exit codes: 0 ok · 2 usage error (bad host/subcommand/flag) · 1 runtime error.
#
# Bundled with the skill and run directly by the orchestrator (which already has a
# bash shell — the ready-to-run command, with plugin root + host substituted, is
# injected by the session-start hook). Uses `set -uo pipefail` WITHOUT `-e`: git
# lookups on a non-git or detached-HEAD checkout must degrade to an "unknown branch"
# result, not abort the script.

set -uo pipefail

usage() {
    cat <<'EOF'
Mint the ingrain-security assessment-file path. Prints one JSON object to stdout.

Usage:
  assessment-path <host> mint --title "<task title>" [--branch-slug <slug>]
  assessment-path --help

Arguments:
  <host>              config dotfolder base name: claude | codex | <future token>
                      (selects project-root resolution only; not part of the path)

mint flags:
  --title T           the ## Task title; slugified into the filename (optional).
  --branch-slug S     reuse an already-resolved branch slug (optional; else resolved
                      from git). Any unresolvable segment is dropped from the name.

Output (relative assessment_path is canonical; assessment_abs is absolute):
  ingrain-security/assessment-<branch-slug>-<task-slug>.md
  Fallbacks: no branch -> assessment-<task-slug>.md; no title -> assessment-<branch-slug>.md;
  both absent -> assessment.md. The `assessment-` prefix always leads. `file_exists`
  is true when the file already exists (the run resumes the same task's prior analysis).

Exit codes: 0 ok · 2 usage error · 1 runtime error.
EOF
}

# --- helpers (patterns reused from ensure-assessment-dir / session-start) ---------

# Resolve the user's PROJECT root as a normalized forward-slash path. Verbatim from
# ensure-assessment-dir: codex resolves from $PWD alone (and deliberately ignores a
# leaked CLAUDE_PROJECT_DIR); every other host — including future ones — falls to the
# CLAUDE_PROJECT_DIR||$PWD default. The `cd && pwd` idiom normalizes Git Bash paths.
resolve_project_root() {
    if [ "${1:-}" = "codex" ]; then
        cd "$PWD" 2>/dev/null && pwd
    else
        cd "${CLAUDE_PROJECT_DIR:-$PWD}" 2>/dev/null && pwd
    fi
}

# Resolve the current git branch, anchored to the resolved project root. Uses
# `branch --show-current` (fallback `rev-parse --abbrev-ref HEAD`) — never `.git/HEAD`,
# unreliable in a worktree/submodule. Detached HEAD or a non-git dir yields empty
# (git noise swallowed), which callers treat as an unknown branch.
resolve_branch() {
    local root="$1" b
    b="$(git -C "${root}" branch --show-current 2>/dev/null)"
    [ -n "${b}" ] || b="$(git -C "${root}" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    [ "${b}" = "HEAD" ] && b=""
    printf '%s' "${b}"
}

# Slugify: lowercase, reduce every disallowed char to `-`, collapse `-` runs, trim.
# So `feature/foo` -> `feature-foo`, `Feature/Foo Bar` -> `feature-foo-bar`.
slugify() {
    local s
    s="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9-' '-')"
    while [[ "${s}" == *--* ]]; do s="${s//--/-}"; done
    s="${s#-}"
    s="${s%-}"
    printf '%s' "${s}"
}

# Single-pass JSON string escape (from session-start). Orders of magnitude faster
# than a char-by-char loop.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "${s}"
}

# Idempotently ensure the self-ignoring .gitignore (mirrors ensure-assessment-dir M5)
# so the assessment — which can contain analysis of a private codebase — is never
# swept into a commit, even if the SessionStart hook did not run.
seed_gitignore() {
    local ignore="$1/.gitignore"
    [ -f "${ignore}" ] && return 0
    printf '%s\n' \
        '# Assessments here can contain analysis of a private codebase, so they' \
        '# are ignored by default. Share one explicitly with: git add -f <file>' \
        '*' \
        '!.gitignore' \
        > "${ignore}" 2>/dev/null || true
}

# --- subcommand -------------------------------------------------------------------

cmd_mint() {
    local host="$1" host_slug title="" slug_flag="" have_slug="false" project_root
    local branch branch_slug branch_known task_slug name basename
    local assessment_dir assessment_path assessment_abs file_exists
    shift

    while [ $# -gt 0 ]; do
        case "$1" in
            --title)
                [ $# -ge 2 ] || { printf 'assessment-path: --title needs a value\n' >&2; return 2; }
                title="$2"
                shift 2
                ;;
            --branch-slug)
                [ $# -ge 2 ] || { printf 'assessment-path: --branch-slug needs a value\n' >&2; return 2; }
                slug_flag="$2"
                have_slug="true"
                shift 2
                ;;
            *)
                printf 'assessment-path: unknown mint flag "%s"\n' "$1" >&2
                return 2
                ;;
        esac
    done

    project_root="$(resolve_project_root "${host}")"
    [ -n "${project_root}" ] || { printf 'assessment-path: could not resolve project root\n' >&2; return 1; }

    host_slug="$(slugify "${host}")"
    [ -n "${host_slug}" ] || { printf 'assessment-path: invalid host token "%s"\n' "${host}" >&2; return 2; }

    # Reuse the caller's already-resolved slug when given; otherwise resolve from git.
    if [ "${have_slug}" = "true" ]; then
        branch_slug="$(slugify "${slug_flag}")"
        branch=""
    else
        branch="$(resolve_branch "${project_root}")"
        branch_slug="$(slugify "${branch}")"
    fi
    if [ -n "${branch_slug}" ]; then branch_known="true"; else branch_known="false"; fi

    task_slug="$(slugify "${title}")"

    assessment_dir="ingrain-security"

    # Never write into a symlinked target — a crafted repo could redirect it outside
    # the tree (same guard as ensure-assessment-dir). Then ensure the folder and its
    # self-ignoring .gitignore exist before the agent writes the file.
    if [ -L "${project_root}/${assessment_dir}" ]; then
        printf 'assessment-path: %s is a symlink; refusing\n' "${assessment_dir}" >&2
        return 1
    fi
    mkdir -p "${project_root}/${assessment_dir}" 2>/dev/null \
        || { printf 'assessment-path: could not create %s\n' "${assessment_dir}" >&2; return 1; }
    seed_gitignore "${project_root}/${assessment_dir}"

    name="assessment"
    [ "${branch_known}" = "true" ] && name="${name}-${branch_slug}"
    [ -n "${task_slug}" ] && name="${name}-${task_slug}"
    basename="${name}.md"
    assessment_path="${assessment_dir}/${basename}"
    assessment_abs="${project_root}/${assessment_path}"

    if [ -f "${assessment_abs}" ]; then file_exists="true"; else file_exists="false"; fi

    printf '{"host":"%s","project_root":"%s","branch":"%s","branch_slug":"%s","branch_known":%s,"task_slug":"%s","assessment_dir":"%s","assessment_path":"%s","assessment_abs":"%s","basename":"%s","file_exists":%s}\n' \
        "$(escape_for_json "${host_slug}")" \
        "$(escape_for_json "${project_root}")" \
        "$(escape_for_json "${branch}")" \
        "${branch_slug}" \
        "${branch_known}" \
        "${task_slug}" \
        "${assessment_dir}" \
        "$(escape_for_json "${assessment_path}")" \
        "$(escape_for_json "${assessment_abs}")" \
        "${basename}" \
        "${file_exists}"
}

main() {
    case "${1:-}" in
        -h|--help)
            usage
            return 0
            ;;
        "")
            printf 'assessment-path: missing <host>. Try --help.\n' >&2
            return 2
            ;;
    esac

    local host="$1" subcommand="${2:-}"
    case "${subcommand}" in
        mint) shift 2; cmd_mint "${host}" "$@" ;;
        "")
            printf 'assessment-path: missing subcommand (mint). Try --help.\n' >&2
            return 2
            ;;
        *)
            printf 'assessment-path: unknown subcommand "%s" (mint). Try --help.\n' "${subcommand}" >&2
            return 2
            ;;
    esac
}

main "$@"
