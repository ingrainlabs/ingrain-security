{
  "lock": false,
  "workspace": [],
  "tasks": {
    "test:offline": "deno task test:ts && deno task test:shell",
    "test:ts": "deno task test:static && deno task test:hooks && deno task test:scripts",
    "test:static": "deno test --allow-read static/",
    "test:hooks": "deno test --allow-run=bash --allow-read --allow-write --allow-env hooks/",
    "test:scripts": "deno test --allow-run=bash --allow-read --allow-write --allow-env scripts/",
    "test:shell": "deno test --allow-run=git,shellcheck --allow-read shell/",
    "test:agent": "deno test --allow-run=claude --allow-read --allow-env agents/ skill/trigger.test.ts",
    "test:integration": "INTEGRATION=1 deno test --allow-run=claude,bash --allow-read --allow-env --allow-write .",
    "ci": "deno task lint && deno task fmt:check && deno task test:offline",
    "variants": "deno run --allow-run --allow-read --allow-write --allow-env skillVariantTest/run.ts",
    "lint": "deno lint .",
    "fmt": "deno fmt .",
    "fmt:check": "deno fmt --check ."
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/front-matter": "jsr:@std/front-matter@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1"
  },
  "fmt": {
    "lineWidth": 100
  }
}
